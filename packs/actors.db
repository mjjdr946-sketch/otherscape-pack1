sure", "unspent_upgrades": 0, "nascent": false, "isExtra": false, "description": "", "locked": false, "version": "1", "tags": [], "improvements": {}, "attention": [0, 0, 0], "crack": [0, 0, 0], "milestone": [0, 0, 0], "subtype": "", "mystery": "Avant de venir à Tokyo, Wilson a servi dans une force militaire internationale ou corporative non divulguée. Son service l'a endurci et lui a inculqué la détermination et les compétences d'un soldat — mais aussi des cicatrices, se manifestant par son refus de revisiter ses souvenirs de bataille."}, "_id": "2KGzt6hNQnpTpSm2", "img": "icons/svg/item-bag.svg", "effects": [], "folder": null, "sort": 0, "flags": {}, "ownership": {"default": 0}}, {"name": "Passé militaire", "type": "tag", "system": {"subtype": "power", "theme_id": "2KGzt6hNQnpTpSm2", "question_letter": "A", "question": "See Otherscape Core p.215", "crispy": false, "custom_tag": false, "subtagRequired": false, "description": "", "locked": false, "version": "1", "category": "none", "burn_state": 0, "burned": false, "is_bonus": false, "broad": false, "temporary": false, "permanent": false, "parentId": null, "showcased": false, "activated_loadout": false, "sceneId": null, "createdBy": [], "example0": "", "example1": "", "example2": "", "counterexample0": "", "counterexample1": "", "counterexample2": "", "restriction0": "", "restriction1": "", "restriction2": ""}, "_id": "ZPBHJt54kUfkoQHp", "img": "icons/svg/item-bag.svg", "effects": [], "folder": null, "sort": 0, "flags": {}, "ownership": {"default": 0}}, {"name": "Force d'oni", "type": "tag", "system": {"subtype": "power", "theme_id": "2KGzt6hNQnpTpSm2", "question_letter": "B", "question": "See Otherscape Core p.215", "crispy": false, "custom_tag": false, "subtagRequired": false, "description": "", "locked": false, "version": "1", "category": "none", "burn_state": 0, "burned": false, "is_bonus": false, "broad": false, "temporary": false, "permanent": false, "parentId": null, "showcased": false, "activated_loadout": fa