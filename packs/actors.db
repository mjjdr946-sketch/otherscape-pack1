", "unspent_upgrades": 0, "nascent": false, "isExtra": false, "description": "", "locked": false, "version": "1", "tags": [], "improvements": {}, "attention": [0, 0, 0], "crack": [0, 0, 0], "milestone": [0, 0, 0], "subtype": "", "mystery": "Lors d'une expédition de récupération dans les secteurs en ruine, Unagi a trouvé un étang souterrain lumineux où nageaient des anguilles géantes. Elle y retourne régulièrement et reçoit la bénédiction d'Unagi Hime, la Princesse Anguille — un don qui améliore ses capacités de récupératrice."}, "_id": "0Ra4sc9ELk21tDM1", "img": "icons/svg/item-bag.svg", "effects": [], "folder": null, "sort": 0, "flags": {}, "ownership": {"default": 0}}, {"name": "Princesse Anguille", "type": "tag", "system": {"subtype": "power", "theme_id": "0Ra4sc9ELk21tDM1", "question_letter": "A", "question": "See Otherscape Core p.215", "crispy": false, "custom_tag": false, "subtagRequired": false, "description": "", "locked": false, "version": "1", "category": "none", "burn_state": 0, "burned": false, "is_bonus": false, "broad": false, "temporary": false, "permanent": false, "parentId": null, "showcased": false, "activated_loadout": false, "sceneId": null, "createdBy": [], "example0": "", "example1": "", "example2": "", "counterexample0": "", "counterexample1": "", "counterexample2": "", "restriction0": "", "restriction1": "", "restriction2": ""}, "_id": "mhKSaCJj4NyLlx8Y", "img": "icons/svg/item-bag.svg", "effects": [], "folder": null, "sort": 0, "flags": {}, "ownership": {"default": 0}}, {"name": "Peau glissante", "type": "tag", "system": {"subtype": "power", "theme_id": "0Ra4sc9ELk21tDM1", "question_letter": "B", "question": "See Otherscape Core p.215", "crispy": false, "custom_tag": false, "subtagRequired": false, "description": "", "locked": false, "version": "1", "category": "none", "burn_state": 0, "burned": false, "is_bonus": false, "broad": false, "temporary": false, "permanent": false, "parentId": null, "showcased": false, "activated_loadout": false,