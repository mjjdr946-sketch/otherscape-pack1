ership": {"default": 0}}, {"name": "Unnamed Esoterica Theme", "type": "theme", "system": {"themebook_id": "f0Hldws5yB2ezw1Z", "themebook_name": "Esoterica", "unspent_upgrades": 0, "nascent": false, "isExtra": false, "description": "", "locked": false, "version": "1", "tags": [], "improvements": {}, "attention": [0, 0, 0], "crack": [0, 0, 0], "milestone": [0, 0, 0], "subtype": "", "mystery": "Wilson a trouvé un masque d'oni qui ne peut pas enlever — ou ne s'en souvient plus quand il l'a enlevé pour la dernière fois. Ses rêves sont hantés par des visions démoniaques. La force surhumaine qu'il en tire a un prix."}, "_id": "duMyWV3KImCHvkGC", "img": "icons/svg/item-bag.svg", "effects": [], "folder": null, "sort": 0, "flags": {}, "ownership": {"default": 0}}, {"name": "Régénération rapide", "type": "tag", "system": {"subtype": "power", "theme_id": "duMyWV3KImCHvkGC", "question_letter": "A", "question": "See Otherscape Core p.219", "crispy": false, "custom_tag": false, "subtagRequired": false, "description": "", "locked": false, "version": "1", "category": "none", "burn_state": 0, "burned": false, "is_bonus": false, "broad": false, "temporary": false, "permanent": false, "parentId": null, "showcased": false, "activated_loadout": false, "sceneId": null, "createdBy": [], "example0": "", "example1": "", "example2": "", "counterexample0": "", "counterexample1": "", "counterexample2": "", "restriction0": "", "restriction1": "", "restriction2": ""}, "_id": "uCRcesgH4a4yuFYK", "img": "icons/svg/item-bag.svg", "effects": [], "folder": null, "sort": 0, "flags": {}, "ownership": {"default": 0}}, {"name": "Odorat aigu", "type": "tag", "system": {"subtype": "power", "theme_id": "duMyWV3KImCHvkGC", "question_letter": "B", "question": "See Otherscape Core p.219", "crispy": false, "custom_tag": false, "subtagRequired": false, "description": "", "locked": false, "version": "1", "category": "none", "burn_state": 0, "burned": false, "is_bonus": false, "broad": false, "temporary": false, "p